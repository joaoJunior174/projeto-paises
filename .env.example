# Servidor local acessível por IP
PORT=3000
# 0.0.0.0 = escuta em todas as interfaces (obrigatório para acesso externo)
HOST=0.0.0.0
# Quando tiver o IP público do seu PC/roteador, preencha abaixo (só para exibir no console)
PUBLIC_IP=
NODE_ENV=development

# PostgreSQL local
DB_HOST=localhost
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=paises
